<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>formulário  de login</title>
</head>
<body>
    <h1>Formulario de login</h1>
    <form action="cadastro" method="post">
        <label for="usuario">Digite o nomme de usuario: </label>
        <input type="text" name="usuario" id="cxUusario"> <br>

        <label for="senha">Infrome sua senha: </label>
        <input type="password" name="senha" id="cxSenha">

        <button type="submit">Entrar</button>
    </form>
</body>
</html>